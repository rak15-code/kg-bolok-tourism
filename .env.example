# ──────────────────────────────────────────────────────────────
# FRONTEND env — copy to `.env` at the project root.
# Only VITE_-prefixed vars are exposed to the browser (this is intentional).
# NEVER put the Supabase SERVICE ROLE key or HitPay secrets here.
# ──────────────────────────────────────────────────────────────

# Backend (server/) base URL
VITE_API_BASE_URL=http://localhost:5000

# Supabase — the ANON key is public by design (protected by RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
