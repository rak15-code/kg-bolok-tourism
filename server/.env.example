# ──────────────────────────────────────────────────────────────
# server/.env.example
# Copy to `server/.env` and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS).
ALLOWED_ORIGIN=http://localhost:5173

# ── Payments ──────────────────────────────────────────────────
# Active provider: "mock" (default, simulates success) or "hitpay".
# You can switch here OR by changing one import in
# services/payments/paymentProvider.js.
PAYMENT_PROVIDER=mock

# Where the user is sent after paying / cancelling.
PAYMENT_SUCCESS_URL=http://localhost:5173/payment/success
PAYMENT_FAILED_URL=http://localhost:5173/payment/failed

# ── HitPay (only needed when PAYMENT_PROVIDER=hitpay) ──────────
HITPAY_API_KEY=
HITPAY_SALT=
HITPAY_API_BASE=https://api.sandbox.hit-pay.com/v1
HITPAY_REDIRECT_URL=http://localhost:5173/payment/success
HITPAY_WEBHOOK_URL=
# (HITPAY_REDIRECT_URL/HITPAY_WEBHOOK_URL fall back to PAYMENT_*_URL / ALLOWED_ORIGIN)

# ── Supabase ──────────────────────────────────────────────────
# SERVICE ROLE key is SECRET — server only, bypasses RLS. Never expose it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI (assistant + virtual tour) ────────────────────────────
# Provider: "gemini" (default) or "anthropic". Keys are secret — server only.
# Without the selected provider's key, AI features disable gracefully.
AI_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Email (Resend) ────────────────────────────────────────────
# Provider: "resend" or "log" (logs to console + email_logs, no real send).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="Kg Bolok Tourism <bookings@yourdomain.com>"
EMAIL_REPLY_TO=info@kgboloktourism.my
