# ──────────────────────────────────────────────────────────────
# .env.example
# Copy this file to `.env` in the same folder and fill in your
# REAL HitPay credentials. Never commit the real `.env`.
# ──────────────────────────────────────────────────────────────

# Server settings
PORT=5000
ALLOWED_ORIGIN=http://localhost:5173

# HitPay credentials — get these from your HitPay dashboard.
# Start in SANDBOX mode (https://api.sandbox.hit-pay.com).
HITPAY_API_KEY=
HITPAY_SALT=
HITPAY_API_BASE=https://api.sandbox.hit-pay.com/v1

# Where HitPay should send the user after payment:
HITPAY_REDIRECT_URL=http://localhost:5173/payment/success
HITPAY_CANCEL_URL=http://localhost:5173/payment/cancel

# Server-to-server callback (must be a public URL in production).
# In local dev, leave blank or use a tunnel like ngrok.
HITPAY_WEBHOOK_URL=
